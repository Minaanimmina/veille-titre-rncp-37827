# Fichier d'exemple, à copier en .env et à compléter
# Le .env réel ne doit jamais être commité (voir .gitignore)

# --- N8N, accès à l'interface web ---
# Identifiant et mot de passe de l'authentification basic N8N
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_a_generer_avec_openssl_rand

# --- N8N, chiffrement des credentials stockés ---
# Clé de chiffrement des credentials, à générer une fois et à conserver
# Génération, openssl rand -hex 32
# ATTENTION, perdre cette cle rend illisibles les credentials existants
N8N_ENCRYPTION_KEY=change_me_a_generer_avec_openssl_rand_hex_32

# --- Chemin absolu du vault Obsidian ---
# Le workflow N8N ecrit les syntheses dans ce vault via le volume monte
# Exemple Linux, /home/utilisateur/Documents/vault-obsidian
# Exemple macOS, /Users/utilisateur/Documents/vault-obsidian
# Exemple Windows WSL, /mnt/c/Users/utilisateur/Documents/vault-obsidian
OBSIDIAN_VAULT_PATH=/chemin/absolu/vers/vault-obsidian

# --- Cles API des services externes ---
# Ces cles sont renseignees dans les credentials N8N, pas ici
# Elles sont listees ici uniquement pour rappel de ce qui est necessaire
# Tavily, https://app.tavily.com, formule gratuite 1000 req/mois
# TAVILY_API_KEY=a_renseigner_dans_n8n
# Groq, https://console.groq.com, compte AFI dedie
# GROQ_API_KEY=a_renseigner_dans_n8n